{
  "program": "PRV1F-01",
  "artifact": "daily_runtime_loop_policy",
  "created_at_utc": "2026-05-04T13:14:29Z",
  "purpose": "Run the personal runtime V1 daily loop with one command: staged credentialed refresh, post-refresh lifecycle update, candidate detection, panel regeneration, final proofs.",
  "daily_loop_steps": [
    {
      "step_id": "preflight",
      "required": true,
      "description": "Check package scope, required scripts, credential env var, and prior state files."
    },
    {
      "step_id": "staged_credentialed_refresh",
      "required": true,
      "script": "scripts/run_staged_credentialed_refresh.py",
      "description": "Rate-limit-aware read-only provider refresh and cache update."
    },
    {
      "step_id": "post_refresh_lifecycle_update",
      "required": true,
      "script": "scripts/run_post_refresh_candidate_lifecycle_update.py",
      "description": "Update existing exact SOT02 lifecycle rows from refreshed cache; do not fabricate new candidate detection."
    },
    {
      "step_id": "candidate_detection",
      "required": true,
      "preferred_script": "scripts/run_candidate_detection_rule_engine_cache_read_fix.py",
      "fallback_script": "scripts/run_candidate_detection_rule_engine.py",
      "description": "Scan local cache with bounded observation rules and dedupe against existing registry."
    },
    {
      "step_id": "daily_panel_and_proofs",
      "required": true,
      "description": "Build final daily panel, status, heartbeat, validation and boundary proofs."
    }
  ],
  "stop_policy": {
    "stop_on_staged_refresh_failure": true,
    "stop_on_post_refresh_update_failure": true,
    "stop_on_candidate_detection_validation_failure": true,
    "candidate_count_zero_is_allowed": true,
    "rate_limit_failure_is_not_accepted_for_daily_pass": true,
    "strict_cache_read_required_for_candidate_detection": true
  },
  "active_instruments_required": [
    "XAUUSD",
    "EURUSD",
    "USDJPY"
  ],
  "forbidden_active_instruments": [
    "SPX",
    "NQ"
  ],
  "credential_policy": {
    "env_var": "LFB_TWELVE_DATA_API_KEY",
    "api_key_must_remain_local_env_only": true,
    "env_file_must_not_be_read": true,
    "secrets_must_not_be_written_to_outputs": true
  },
  "out_of_scope": [
    "broker",
    "order",
    "execution",
    "demo_trading",
    "live_trading",
    "signal",
    "buy_sell_hold",
    "entry_stop_target",
    "pnl_win_loss",
    "optimizer",
    "validation_verdict",
    "adaptation_decision",
    "production_readiness",
    "source2",
    "calendar_event"
  ],
  "boundary": {
    "runtime_observation_not_signal": true,
    "candidate_not_trade_recommendation": true,
    "outcome_observation_not_win_loss": true,
    "lifecycle_tracking_not_execution_tracking": true,
    "cache_not_source_authority": true,
    "single_provider_confidence_not_source_truth": true,
    "scheduler_heartbeat_not_production_readiness": true,
    "panel_payload_not_action_surface": true,
    "no_broker": true,
    "no_order": true,
    "no_execution": true,
    "no_buy_sell_hold": true,
    "no_entry_stop_target": true,
    "no_pnl": true,
    "no_optimizer": true,
    "no_validation_verdict": true,
    "no_adaptation_decision": true,
    "no_production_readiness_claim": true,
    "spx_nq_out_of_v1_active_scope": true,
    "calendar_event_out_of_v1_scope": true,
    "second_provider_out_of_v1_scope": true,
    "row_2_retained_unopened": true,
    "rows_6_7_deferred_reentry": true,
    "matrix_complete_not_matrix_open": true
  }
}