{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIG-E Shadow Detector Schema v1.0",
  "type": "object",
  "required": [
    "detector_id",
    "program",
    "source_spec_id",
    "instrument",
    "direction",
    "session_bucket",
    "authority",
    "boundary"
  ],
  "properties": {
    "detector_id": {
      "type": "string"
    },
    "program": {
      "const": "SIG-E-RUNTIME-SHADOW-DETECTOR1"
    },
    "source_spec_id": {
      "type": "string"
    },
    "instrument": {
      "type": "string"
    },
    "direction": {
      "type": "string"
    },
    "session_bucket": {
      "type": "string"
    },
    "authority": {
      "type": "object"
    },
    "boundary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}