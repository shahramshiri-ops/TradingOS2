{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIG-E Runtime Spec Schema v1.0",
  "type": "object",
  "required": [
    "spec_id",
    "program",
    "status",
    "runtime_authority",
    "boundary",
    "lane",
    "regime_contract",
    "setup_contract",
    "h1_trigger_contract",
    "m15_trigger_contract",
    "evidence"
  ],
  "properties": {
    "spec_id": {
      "type": "string"
    },
    "program": {
      "const": "SIG-E-RUNTIME-SPEC1"
    },
    "status": {
      "type": "string"
    },
    "runtime_authority": {
      "type": "object"
    },
    "boundary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lane": {
      "type": "object"
    },
    "regime_contract": {
      "type": "object"
    },
    "setup_contract": {
      "type": "object"
    },
    "h1_trigger_contract": {
      "type": "object"
    },
    "m15_trigger_contract": {
      "type": "object"
    },
    "evidence": {
      "type": "object"
    }
  }
}