{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIG Memory Context Requirements Schema v1.0",
  "type": "object",
  "required": [
    "memory_id",
    "required_context_fields"
  ],
  "properties": {
    "memory_id": {
      "type": "string"
    },
    "required_context_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "matching_rule": {
      "type": "object"
    }
  }
}