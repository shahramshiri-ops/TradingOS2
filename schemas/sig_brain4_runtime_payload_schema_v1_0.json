{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIG-BRAIN4 Runtime Payload Schema",
  "type": "object",
  "required": [
    "payload_version",
    "created_utc",
    "authority",
    "signal_authorized",
    "cards",
    "registry_summary"
  ],
  "properties": {
    "payload_version": {
      "type": "string"
    },
    "created_utc": {
      "type": "string"
    },
    "authority": {
      "type": "string"
    },
    "signal_authorized": {
      "const": false
    },
    "action_surface_authorized": {
      "const": false
    },
    "cards": {
      "type": "array"
    },
    "registry_summary": {
      "type": "object"
    }
  }
}