{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIG Context Field Registry Schema v1.0",
  "type": "object",
  "required": [
    "registry_version",
    "fields"
  ],
  "properties": {
    "registry_version": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field_id",
          "family",
          "module",
          "dtype",
          "meaning_fa",
          "current_brain5_support"
        ],
        "properties": {
          "field_id": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "module": {
            "type": "string"
          },
          "dtype": {
            "type": "string"
          },
          "meaning_fa": {
            "type": "string"
          },
          "current_brain5_support": {
            "type": "boolean"
          }
        }
      }
    }
  }
}