name: SIG Brain4 Display-Only Mobile Panel

on:
  workflow_dispatch:
  push:
    paths:
      - 'data/sig_brain/**'
      - 'inputs/sig_brain4_live_context_latest.json'
      - 'scripts/build_sig_brain4_runtime_payload.py'
      - 'panel/brain4/**'

concurrency:
  group: sig-brain4-display-only-mobile-panel
  cancel-in-progress: true

jobs:
  build-brain4-panel:
    runs-on: ubuntu-latest
    permissions:
      contents: write
      actions: write
      pages: write
      id-token: write
    steps:
      - uses: actions/checkout@v4
      - name: Build SIG Brain4 display-only runtime payload
        run: |
          python scripts/build_sig_brain4_runtime_payload.py
          python scripts/validate_sig_brain4_outputs.py
          python scripts/run_sig_shadow_01b_integrated.py
          python scripts/run_sig_shadow_ready_01.py
      # SHADOW-DIAG-01 — near-miss/blocker/eligibility diagnostics (NOT_SIGNAL)
      - name: Build SHADOW-DIAG-01 diagnostics
        run: python scripts/run_sig_shadow_diag_01.py

      # SHADOW-OPS-01 — diagnostics, eligibility, rollups, health (NOT_SIGNAL)
      - name: Build SHADOW-OPS-01 operational diagnostics
        run: python scripts/run_sig_shadow_ops_01.py

      # REASON-UPSTREAM-01 / DIAG-02 — enrich near-miss reason codes (NOT_SIGNAL)
      - name: Build REASON-UPSTREAM-01 near-miss reason source
        run: python scripts/run_sig_shadow_reason_upstream_01.py

      - name: Commit generated display-only payload
        id: commit_generated
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"
          git add runtime/sig_brain/sig_brain4_runtime_payload_current.json panel/brain4/sig_brain4_runtime_payload_current.json proofs/sig_brain4_validation_result.json runtime/sig_signal_candidates runtime/sig_shadow
          if git diff --cached --quiet; then
            echo "No generated changes"
            echo "changed=false" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          git commit -m "Update SIG Brain4 display-only payload"
          git pull --rebase --autostash origin "${GITHUB_REF_NAME}"
          git push origin "HEAD:${GITHUB_REF_NAME}"
          echo "changed=true" >> "$GITHUB_OUTPUT"
      - name: Trigger static Pages deploy after generated commit
        if: steps.commit_generated.outputs.changed == 'true'
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          gh workflow run deploy_tradingos_pages.yml --ref "${GITHUB_REF_NAME}"
